{
  "poll_seconds": 10,
  "start_after_consecutive_detections": 2,
  "stop_after_consecutive_misses": 4,
  "max_recording_minutes": 180,
  "output_dir": "~/.meeting-transcriber/output",
  "log_file": "~/.meeting-transcriber/meeting-transcriber.log",
  "browser_apps": [
    "Google Chrome",
    "Microsoft Edge",
    "Brave Browser",
    "Arc",
    "Safari"
  ],
  "recording_backend": "dashboard_command",
  "dashboard_command_file": "~/.meeting-transcriber/dashboard-command.json",
  "dashboard_app_path": "/Applications/Meeting Transcriber Dashboard.app",
  "record_command": [
    "/Applications/Native Meeting Recorder.app/Contents/MacOS/native-meeting-recorder",
    "--output",
    "{output}",
    "--status-file",
    "{status}",
    "--max-seconds",
    "10800"
  ],
  "audio_extension": "mp4",
  "status_file": "~/.meeting-transcriber/status.json",
  "transcribe_after_recording": true,
  "transcribe_python": "~/.meeting-transcriber/venv/bin/python",
  "transcription_worker": "~/.meeting-transcriber/app/transcribe_recording.py",
  "transcribe_output_format": "md",

  "_comment_providers": "Local Whisper is the always-available floor. API providers unlock by setting their key env var. transcribe_provider/summary_provider pick the primary; *_fallback lists are tried in order, then any other available provider, ending at the local floor.",
  "transcribe_provider": "local_whisper",
  "transcribe_fallback": ["openai"],
  "summary_provider": "openai",
  "summary_fallback": ["openrouter"],
  "models_dir": "~/.meeting-transcriber/models",
  "whisper_auto_download": true,
  "whisper_language": "auto",
  "providers": {
    "local_whisper": {
      "transcribe": {
        "type": "whisper_cpp",
        "model": "large-v3-turbo-q5_0",
        "model_url": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo-q5_0.bin"
      }
    },
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "key_env": "OPENAI_API_KEY",
      "transcribe": { "type": "openai_audio", "model": "gpt-4o-mini-transcribe", "diarize_model": "gpt-4o-transcribe-diarize" },
      "summarize": { "type": "openai_chat", "model": "gpt-4o-mini" }
    },
    "openrouter": {
      "base_url": "https://openrouter.ai/api/v1",
      "key_env": "OPENROUTER_API_KEY",
      "summarize": { "type": "openai_chat", "model": "anthropic/claude-3.5-sonnet" }
    }
  },

  "summary": "on",
  "_comment_meeting_owner": "Optional. When set, first-person action items are attributed to this name. Leave empty for speaker-neutral notes.",
  "meeting_owner": "",
  "meeting_owner_aliases": [],
  "summary_max_chars": 120000,
  "snippet_seconds": 180,
  "_comment_min_transcribe_seconds": "Recordings shorter than this are skipped before any API call.",
  "min_transcribe_seconds": 20,
  "max_parallel_transcriptions": 3,
  "orphan_job_min_age_seconds": 180,
  "recorder_stop_grace_seconds": 30
}
